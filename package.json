{
  "name": "en-iptv",
  "version": "0.1.0",
  "private": true,
  "description": "EN IPTV Player — open-source IPTV player for Samsung Tizen TVs and desktop browsers",
  "type": "module",
  "workspaces": [
    "packages/server",
    "packages/proxy",
    "packages/player",
    "packages/tizen"
  ],
  "scripts": {
    "dev": "npm run dev -w packages/player",
    "server": "node packages/server/server.mjs",
    "proxy": "node packages/proxy/proxy.mjs",
    "build": "npm run build -w packages/player",
    "preview": "npm run preview -w packages/player",
    "tizen": "npm run build && node packages/tizen/package.mjs",
    "tizen:deploy": "node packages/tizen/install.mjs",
    "start": "concurrently \"npm run server\" \"npm run proxy\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
